# Agent (payer) private key — the wallet that deposits tokens into the channel
PRIVATE_KEY=

# Service (payee) private key — the wallet that receives payments
# Use a DIFFERENT key than PRIVATE_KEY (two separate wallets)
SERVICE_PRIVATE_KEY=

# Service address — the payee address (derived from SERVICE_PRIVATE_KEY)
PAYEE_ADDRESS=

# Service URL (default: http://localhost:3402)
SERVICE_URL=http://localhost:3402
SERVICE_PORT=3402
